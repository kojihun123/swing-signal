# 텔레그램 봇 (없으면 텔레그램 전송 skip, 터미널 출력만)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Gemini API (없으면 LLM 종합 분석 skip, 기계적 스코어만 사용)
GEMINI_API_KEY=

# FRED API (없으면 거시경제 금리/물가/고용 skip → 거시 보정 미적용, VIX/Fear&Greed만 표시)
# 무료 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Finnhub API (없으면 가격을 yfinance/Finviz로 폴백 → 수 분 지연)
# 무료 실시간 미국 주식 시세(60콜/분). 발급: https://finnhub.io
FINNHUB_API_KEY=

# 한국투자증권 KIS API (미국 데이마켓/주간거래 포함 전 세션 시세)
# 무료 소스가 못 잡는 오버나잇(한국 낮시간) 가격을 커버. 1순위 소스로 사용.
# 한투 계좌 + https://apiportal.koreainvestment.com 에서 App Key/Secret 발급
KIS_APP_KEY=
KIS_APP_SECRET=
